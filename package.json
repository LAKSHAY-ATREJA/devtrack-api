{
  "name": "devtrack-api",
  "version": "1.0.0",
  "description": "REST API for tracking job applications with JWT auth, tests, Docker and CI/CD",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "build": "echo 'No build step required for Node.js' && exit 0",
    "test": "jest --runInBand --detectOpenHandles --forceExit",
    "test:cov": "jest --coverage --runInBand --detectOpenHandles --forceExit",
    "lint": "eslint src tests"
  },
  "keywords": ["rest-api", "express", "mongodb", "jwt", "nodejs"],
  "author": "Lakshay Atreja",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.2",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.2.0",
    "nodemon": "^3.1.0",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18"
  }
}
